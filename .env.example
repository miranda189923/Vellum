# Vellum Environment Configuration

# The URL where the app is hosted
APP_URL=http://localhost:3000

# --- AI Configuration ---
# Read by the server only; don't prefix with VITE_ (that would expose them to the browser).
# Supported providers: "gemini", "openai", "grok", "anthropic", "groq", "openrouter"

# Format:
# AI_CONFIGS='[
#   {"provider": "provider_name", "key": "YOUR_API_KEY", "model": "model_name"},
#   {"provider": "provider_name2", "key": "YOUR_API_KEY", "model": "model_name2"}    
# ]'
#

# Example:
AI_CONFIGS='[
  {"provider": "openai", "key": "YOUR_OPENAI_API_KEY", "model": "gpt-4o-mini"}
]'