# Vellum Environment Configuration

# The URL where the app is hosted
APP_URL=http://localhost:3000

# --- AI Configuration ---
# These keys are read by the server only (aiService.ts) and are never exposed to
# the browser. Do NOT prefix them with VITE_ — that would bundle them into the client.
# Supported providers: "gemini", "openai", "grok", "anthropic", "groq"

# Format:
# AI_CONFIGS='[
#   {"provider": "provider_name", "key": "YOUR_API_KEY", "model": "model_name"},
#   {"provider": "provider_name2", "key": "YOUR_API_KEY", "model": "model_name2"}    
# ]'
#

# Example:
AI_CONFIGS='[
  {"provider": "openai", "key": "YOUR_OPENAI_API_KEY", "model": "gpt-4o-mini"}
]'